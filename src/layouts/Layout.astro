---
import { Icon } from "astro-icon/components";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <body>
    <header class="flex gap-8 justify-between px-12 py-4">
      <div class="flex justify-start">
        <a href="/" class="font-serif font-bold text-2xl text-[#362C24]"
          >UNITS</a
        >
      </div>

      <div class="flex gap-13 justify-center">
        <a href="/pants" class="font-serif font-bold text-lg text-[#362C24] transition-transform duration-150 hover:scale-120"
          >Pants</a
        >
        <a href="/Tops" class="font-serif font-bold text-lg text-[#362C24] transition-transform duration-150 hover:scale-120"
          >Tops</a
        >
        <a href="/shopall" class="font-serif font-bold text-lg text-[#362C24] transition-transform duration-150 hover:scale-120"
          >Shop all</a
        >
      </div>

      <div class="flex justify-end transition-transform duration-300 hover:scale-120">
        <a href="/cart"><Icon name="marron" size={30}/></a>
      </div> 
    </header>
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
