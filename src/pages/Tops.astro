---
import Layout from "../layouts/Layout.astro";
---

<Layout>

<section class="flex flex-col gap-10">
        <div class="flex justify-center gap-10">
            <div class="flex flex-col">
                <img src="/black-hoodie.png" alt="" class="w-[400px] hover:opacity-80" />
                <p class="flex justify-center mt-4 text-[11px] tracking-[0.2em] uppercase font-medium">BLACK QUARTER ZIP 150$</p>
            </div>
            <div class="flex flex-col">
                <img src="/blue-shirt.png" alt="" class="w-[400px] hover:opacity-80" />
                <p class="flex justify-center mt-4 text-[11px] tracking-[0.2em] uppercase font-medium">SKY BLUE T-SHIRT 60$</p>
            </div>
            
        </div>
        <div class="flex justify-center gap-10">
            <div class="flex flex-col">
                <img src="/brown-jacket.png" alt="" class="w-[400px] hover:opacity-80" />
                <p class="flex justify-center mt-4 text-[11px] tracking-[0.2em] uppercase font-medium">BROWN JACKET 210$</p>
            </div>
            <div class="flex flex-col">
                <img src="/green-hoodie.png" alt="" class="w-[400px] hover:opacity-80" />
                <p class="flex justify-center mt-4 text-[11px] tracking-[0.2em] uppercase font-medium">GREEN HOODIE 150$</p>
            </div>
            
        </div>
    </section>
    
</Layout>