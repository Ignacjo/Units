            <div class="flex flex-col">
                <img src="/vici.png" alt="" class="w-[400px] hover:opacity-80" />
                <p class="flex justify-center mt-4 text-[11px] tracking-[0.2em] uppercase font-medium">YELLOW TINTED DENIM 110$</p>
            </div>
            <div class="flex flex-col">
                <img src="/coffee.png" alt="" class="w-[400px] hover:opacity-80" />
                <p class="flex justify-center mt-4 text-[11px] tracking-[0.2em] uppercase font-medium">BROWN DENIM 110$</p>
            </div>
            
        </div>
        <div class="flex justify-center gap-10">
            <div class="flex flex-col">
                <img src="/azul.png" alt="" class="w-[400px] hover:opacity-80" />
                <p class="flex justify-center mt-4 text-[11px] tracking-[0.2em] uppercase font-medium">BLUE DENIM 110$</p>
            </div>
            <div class="flex flex-col">
                <img src="/faded.png" alt="" class="w-[400px] hover:opacity-80" />
