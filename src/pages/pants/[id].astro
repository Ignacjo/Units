---
import Layout from "../../layouts/Layout.astro";
import pants from "../../data/pants";

export async function getStaticPaths() {
    return pants.map((producto) => ({
        params: { id: producto.id },
        props: { producto }
    }));
}

const { producto } = Astro.props;
---

<Layout>
    <div class="px-20 py-16">
        <a href="/pants" class="font-sans text-sm uppercase tracking-[0.3em] text-[#7C8082] hover:underline mb-8 inline-block">
             Back to pants
        </a>

        <section class="flex flex-col gap-10 rounded-[2rem] bg-[#FBFBFB] p-10 shadow-[0_30px_60px_rgba(54,44,36,0.05)] md:flex-row md:items-start">
            <img src={producto.imagen} alt={producto.titulo} class="w-full max-w-[520px] rounded-[2rem] object-cover" />

            <div class="flex flex-1 flex-col justify-between gap-8">
                <div class="space-y-6">
                    <p class="text-sm uppercase tracking-[0.3em] text-[#7C8082]">Pants</p>
                    <h1 class="text-5xl font-serif text-[#362C24]">{producto.titulo.replace(/\s+\d+\$$/, '')}</h1>
                    <p class="max-w-2xl text-base leading-8 text-[#7C8082]">{producto.description}</p>
                    <p class="text-3xl font-bold text-[#362C24]">{producto.titulo.split(' ').pop()}</p>
                    <button class="rounded-full bg-[#362C24] px-8 py-4 text-base font-bold text-[#BAD8E0] transition duration-200 hover:bg-[#524536]">
                        Add to cart
                    </button>
                </div>

                <div class="grid gap-6 sm:grid-cols-2">
                    {producto.details.map((detail) => (
                        <div class="rounded-[1.5rem] border border-[#E7E6E6] p-6">
                            <p class="text-xs uppercase tracking-[0.3em] text-[#7C8082]">Detail</p>
                            <p class="mt-3 text-sm leading-6 text-[#362C24]">{detail}</p>
                        </div>
                    ))}
                </div>
            </div>
        </section>
    </div>
</Layout>